# Database — defaults to SQLite (no setup required).
# Set DATABASE_URL to a PostgreSQL connection string to use PostgreSQL.
# DATABASE_URL=postgresql://postgres:your_password@localhost:5432/ledgr
# SQLITE_PATH=data/ledgr.db

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate_with_openssl_rand_base64_32
AUTH_TRUST_HOST=true

# Cron job authentication — required in production (startup fails without it)
CRON_SECRET=generate_with_openssl_rand_base64_32

# At-rest encryption key for budget API credentials (YNAB / Actual).
# Required in production; startup fails without it. 32-byte base64 value.
# Generate with: openssl rand -base64 32
# Not required when DEMO_ONLY=true.
ENCRYPTION_KEY=generate_with_openssl_rand_base64_32

# Dev mode: grant admin to credential-login users (requires no Authentik)
# ALLOW_DEV_MODE=true

# Optional: Authentik OIDC provider (omit for dev-mode credentials login)
# AUTH_AUTHENTIK_ISSUER=https://auth.example.com/application/o/ledgr
# AUTH_AUTHENTIK_ID=your_client_id
# AUTH_AUTHENTIK_SECRET=your_client_secret

# Optional: Demo-only mode (no login, read-only, profile chooser)
# DEMO_ONLY=true

# Optional: SSRF allowlist for Actual Budget server URLs.
# Comma-separated list of hosts allowed to bypass the private-IP block.
# Only needed if your Actual Budget server runs on a private network.
# ALLOWED_ACTUAL_HOSTS=actual.internal.example.com,10.0.0.5

# Budget API credentials (YNAB / Actual Budget) are NOT configured via
# env vars. Sign in as an admin and set them up in Settings → Integrations;
# values are encrypted at rest with ENCRYPTION_KEY before being stored.
