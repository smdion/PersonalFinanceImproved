# Database
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=your_password_here
DATABASE_NAME=ledgr

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate_with_openssl_rand_base64_32
AUTH_TRUST_HOST=true

# Cron job authentication
CRON_SECRET=generate_with_openssl_rand_base64_32

# Dev mode: grant admin to credential-login users (requires no Authentik)
# ALLOW_DEV_MODE=true

# Optional: Authentik OIDC provider (omit for dev-mode credentials login)
# AUTH_AUTHENTIK_ISSUER=https://auth.example.com/application/o/ledgr
# AUTH_AUTHENTIK_ID=your_client_id
# AUTH_AUTHENTIK_SECRET=your_client_secret

# Optional: Demo-only mode (no login, read-only, profile chooser)
# DEMO_ONLY=true

# Optional: Budget API integration
# YNAB_ACCESS_TOKEN=your_ynab_token
# ACTUAL_SERVER_URL=http://localhost:5006
# ACTUAL_PASSWORD=your_actual_password
