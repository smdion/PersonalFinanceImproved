# Deploy configuration — copy to .env.deploy and fill in your values
# .env.deploy is gitignored and will not be committed

# SSH connection to the Docker host
DEPLOY_SSH_KEY=/tmp/ansible_ssh_key
DEPLOY_SSH_HOST=user@10.10.10.52

# Paths on the host (not inside containers)
DEPLOY_BUILD_DIR=/opt/personalfinance
DEPLOY_STACK_DIR=/opt/stacks/dev

# Container names (defaults shown)
DEPLOY_PROD_CONTAINER=ledgr
DEPLOY_DEMO_CONTAINER=ledgrdemo
