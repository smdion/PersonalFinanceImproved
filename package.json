{
  "name": "ledgr",
  "version": "0.3.6",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --max-warnings 0 && prettier --check .",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx db-migrate.ts",
    "db:studio": "drizzle-kit studio",
    "seed": "tsx .scratch/seed/seed.ts",
    "validate": "tsx .scratch/seed/validate.ts",
    "test:coverage": "vitest run --coverage",
    "test:stress": "FAST_CHECK_NUM_RUNS=200 vitest run tests/calculators/engine-invariants.test.ts tests/benchmarks/monte-carlo-properties.test.ts",
    "test:e2e": "playwright test",
    "compare": "tsx .scratch/compare/compare-xlsx-to-live.ts",
    "seed:safe": "pnpm validate && pnpm seed && pnpm validate",
    "docs:verify": "tsx scripts/verify-docs.ts",
    "docs:update": "tsx scripts/verify-docs.ts --update",
    "check:file-size": "bash scripts/check-file-size.sh",
    "check:known-diffs": "tsx scripts/check-known-diffs.ts",
    "release": "bash scripts/release.sh",
    "deploy": "bash scripts/deploy.sh",
    "analyze": "ANALYZE=true pnpm build",
    "check:bundle": "tsx scripts/check-bundle-size.ts",
    "check:migrations": "tsx scripts/check-migrations.ts",
    "check:tax-params": "tsx scripts/check-tax-params.ts",
    "backup:export": "tsx scripts/export-backup.ts",
    "backup:import": "tsx scripts/import-backup.ts",
    "prepare": "husky"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-query": "^5.95.2",
    "@tanstack/react-table": "^8.21.3",
    "@trpc/client": "^11.15.0",
    "@trpc/next": "^11.15.0",
    "@trpc/react-query": "^11.15.0",
    "@trpc/server": "^11.15.0",
    "better-sqlite3": "^12.8.0",
    "drizzle-orm": "^0.45.1",
    "lucide-react": "^1.6.0",
    "next": "16.2.1",
    "next-auth": "5.0.0-beta.30",
    "pg": "^8.20.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.72.0",
    "recharts": "^3.8.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^16.2.1",
    "@playwright/test": "^1.52.0",
    "@tailwindcss/postcss": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.12.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "@vitest/coverage-v8": "^4.1.1",
    "axe-core": "^4.11.1",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "fast-check": "^4.6.0",
    "husky": "^9.1.7",
    "jsdom": "^29.0.1",
    "lint-staged": "^16.4.0",
    "postcss": "^8",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.1",
    "xlsx": "^0.18.5"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css,yaml,yml}": [
      "prettier --write"
    ]
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild",
      "unrs-resolver"
    ],
    "overrides": {
      "flatted": ">=3.4.2"
    }
  }
}
